# Copy to `.secrets` (gitignored) and fill in values for local `act` runs.
# act auto-loads `.secrets` at repo root.
#
# Only needed if a workflow step actually consumes the secret — most of
# anyserial's CI works without any of these set.

# codecov/codecov-action — a fake value is fine locally; uploads will 404
# but the job won't fail (fail_ci_if_error: false).
CODECOV_TOKEN=local-fake-token

# Personal access token for actions that hit the GitHub API (e.g. release
# workflows). Not required for lint / typecheck / test jobs.
# GITHUB_TOKEN=ghp_xxx

# PyPI publish token — only the publish workflow reads this.
# PYPI_API_TOKEN=pypi-xxx
