# act — local GitHub Actions runner config.
# https://nektosact.com/usage/index.html
#
# Run with `make act-*` targets or directly (`act -j lint`).
# Edit `.secrets` / `.env` (gitignored) for tokens and env vars.

# Ubuntu runners → catthehacker "medium" images (closest to ubuntu-latest).
-P ubuntu-latest=catthehacker/ubuntu:act-latest
-P ubuntu-24.04=catthehacker/ubuntu:act-24.04
-P ubuntu-22.04=catthehacker/ubuntu:act-22.04

# Non-Linux runners act cannot emulate. Stubbing to `-self-hosted` makes
# act skip these jobs instead of trying to pull a nonexistent image.
# macOS / Windows / FreeBSD coverage still runs on real GitHub Actions.
-P macos-latest=-self-hosted
-P macos-14=-self-hosted
-P macos-13=-self-hosted
-P windows-latest=-self-hosted

# Reuse containers between runs for much faster iteration.
--reuse

# Skip re-pulling action images every run once cached.
--action-offline-mode

# Local artifact server so actions/upload-artifact@v4 works.
--artifact-server-path /tmp/act-artifacts
